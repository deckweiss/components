{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "changelog-page",
	"title": "Changelog Page",
	"type": "registry:page",
	"description": "A page template for displaying version history with new features, improvements, and bug fixes.",
	"dependencies": [
		"@lucide/svelte"
	],
	"devDependencies": [
		"@lucide/svelte@^0.561.0"
	],
	"registryDependencies": [
		"update-popup",
		"button",
		"card"
	],
	"files": [
		{
			"content": "<script lang=\"ts\">\n\timport { Button } from \"$lib/components/ui/button\";\n\timport { Card } from \"$lib/components/ui/card\";\n\timport {\n\t\tgetAllVersions,\n\t\tgetLatestVersion,\n\t\tshowVersionHighlights,\n\t} from \"$lib/versions/version-manager\";\n\timport { SparklesIcon, TrendingUpIcon, BugIcon } from \"@lucide/svelte\";\n\n\tconst versions = $derived([...getAllVersions()].reverse());\n</script>\n\n<div class=\"space-y-8\">\n\t{#each versions as version (version.version)}\n\t\t<article class=\"bg-card max-w-2xl rounded-lg border p-6 shadow-sm\">\n\t\t\t<div class=\"mb-4 flex flex-wrap items-baseline justify-between gap-2\">\n\t\t\t\t<div class=\"flex flex-wrap items-baseline gap-2\">\n\t\t\t\t\t<h2 class=\"text-foreground text-xl font-semibold\">{version.title}</h2>\n\t\t\t\t\t<span\n\t\t\t\t\t\tclass=\"bg-primary/10 text-primary rounded-md px-2 py-0.5 text-sm font-medium\"\n\t\t\t\t\t>\n\t\t\t\t\t\t{version.version}\n\t\t\t\t\t</span>\n\t\t\t\t\t<span class=\"text-muted-foreground text-sm\">{version.date}</span>\n\t\t\t\t</div>\n\t\t\t\t<Button\n\t\t\t\t\tvariant={getLatestVersion().version === version.version ? \"default\" : \"outline\"}\n\t\t\t\t\tsize=\"sm\"\n\t\t\t\t\tonclick={() => showVersionHighlights(version)}\n\t\t\t\t>\n\t\t\t\t\tHighlights anzeigen\n\t\t\t\t</Button>\n\t\t\t</div>\n\n\t\t\t<div class=\"space-y-4\">\n\t\t\t\t{#if version.detailedChanges.newFeatures.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3\n\t\t\t\t\t\t\tclass=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\"\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t<SparklesIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tNeue Funktionen\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.newFeatures as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\n\t\t\t\t{#if version.detailedChanges.improvements.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3\n\t\t\t\t\t\t\tclass=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\"\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t<TrendingUpIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tVerbesserungen\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.improvements as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\n\t\t\t\t{#if version.detailedChanges.bugFixes.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3\n\t\t\t\t\t\t\tclass=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\"\n\t\t\t\t\t\t>\n\t\t\t\t\t\t\t<BugIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tBugfixes\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.bugFixes as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\t\t\t</div>\n\t\t</article>\n\t{/each}\n</div>\n",
			"type": "registry:component",
			"target": "blocks/changelog-page/changelog-page.svelte"
		},
		{
			"content": "import ChangelogPage from \"./changelog-page.svelte\";\n\nexport { ChangelogPage };\n",
			"type": "registry:file",
			"target": "blocks/changelog-page/index.ts"
		}
	]
}