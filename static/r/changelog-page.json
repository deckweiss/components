{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "changelog-page",
	"title": "Changelog Page",
	"type": "registry:page",
	"description": "A page template for displaying version history with new features, improvements, and bug fixes.",
	"dependencies": [
		"@lucide/svelte"
	],
	"devDependencies": [
		"@lucide/svelte@^0.561.0"
	],
	"registryDependencies": [
		"update-popup",
		"button",
		"card"
	],
	"files": [
		{
			"content": "<script lang=\"ts\">\n\timport { Badge } from \"$lib/components/ui/badge\";\n\timport { Button } from \"$lib/components/ui/button\";\n\timport {\n\t\tgetAllVersions,\n\t\tgetLatestVersion,\n\t\tshowVersionHighlights,\n\t} from \"$lib/versions/version-manager\";\n\timport { SparklesIcon, TrendingUpIcon, BugIcon } from \"@lucide/svelte\";\n\n\tconst versions = $derived([...getAllVersions()].reverse());\n\tconst latestVersion = $derived(getLatestVersion().version);\n</script>\n\n<div class=\"space-y-8\">\n\t{#each versions as version (version.version)}\n\t\t{@const isLatest = version.version === latestVersion}\n\t\t<article\n\t\t\tclass=\"bg-card max-w-2xl rounded-lg border p-6 shadow-sm {isLatest\n\t\t\t\t? 'border-primary/50 ring-primary/20 ring-1'\n\t\t\t\t: ''}\"\n\t\t>\n\t\t\t<!-- Header: title + button (button stays close to heading on all breakpoints) -->\n\t\t\t<div class=\"mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4\">\n\t\t\t\t<div class=\"min-w-0 flex-1 space-y-2\">\n\t\t\t\t\t<div class=\"flex flex-wrap items-center gap-2\">\n\t\t\t\t\t\t<h2 class=\"text-foreground text-xl font-semibold\">{version.title}</h2>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"flex flex-wrap items-center gap-2\">\n\t\t\t\t\t\t<Badge variant=\"secondary\" class=\"text-xs\">{version.date}</Badge>\n\t\t\t\t\t\t<span class=\"text-muted-foreground text-xs\">Version {version.version}</span>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<Button\n\t\t\t\t\tvariant={isLatest ? \"default\" : \"outline\"}\n\t\t\t\t\tsize=\"sm\"\n\t\t\t\t\tclass=\"shrink-0 self-start\"\n\t\t\t\t\tonclick={() => showVersionHighlights(version)}\n\t\t\t\t>\n\t\t\t\t\tHighlights anzeigen\n\t\t\t\t</Button>\n\t\t\t</div>\n\n\t\t\t<div class=\"space-y-4\">\n\t\t\t\t{#if version.detailedChanges.newFeatures.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3 class=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\">\n\t\t\t\t\t\t\t<SparklesIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tNeue Funktionen\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground ml-1.5 list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.newFeatures as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\n\t\t\t\t{#if version.detailedChanges.improvements.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3 class=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\">\n\t\t\t\t\t\t\t<TrendingUpIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tVerbesserungen\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground ml-1.5 list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.improvements as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\n\t\t\t\t{#if version.detailedChanges.bugFixes.length > 0}\n\t\t\t\t\t<section>\n\t\t\t\t\t\t<h3 class=\"text-foreground mb-2 flex items-center gap-2 text-sm font-semibold\">\n\t\t\t\t\t\t\t<BugIcon class=\"text-primary size-4\" />\n\t\t\t\t\t\t\tBugfixes\n\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t<ul class=\"text-muted-foreground ml-1.5 list-inside list-disc space-y-1 text-sm\">\n\t\t\t\t\t\t\t{#each version.detailedChanges.bugFixes as item}\n\t\t\t\t\t\t\t\t<li>{item}</li>\n\t\t\t\t\t\t\t{/each}\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</section>\n\t\t\t\t{/if}\n\t\t\t</div>\n\t\t</article>\n\t{/each}\n</div>\n",
			"type": "registry:component",
			"target": "blocks/changelog-page/changelog-page.svelte"
		},
		{
			"content": "import ChangelogPage from \"./changelog-page.svelte\";\n\nexport { ChangelogPage };\n",
			"type": "registry:file",
			"target": "blocks/changelog-page/index.ts"
		}
	]
}